"""
Configuration file for environment variables.

Copy this file to .env and update values as needed.
The application will automatically load these values.

Example:
    LOG_LEVEL=DEBUG
    MASTER_REPORT_FILE=Master Report.xlsx
"""

# Logging Configuration
LOG_LEVEL=INFO

# File Names (default names, override if your files are named differently)
MASTER_REPORT_FILE=Master Report.xlsx
RETAILER_MAPPING_FILE=retailer_rm_mapping.csv
BEAT_PLAN_FILE=new_beat_plan.csv

# Optional: API keys, credentials, etc.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# EMAIL_RECIPIENT=admin@example.com
